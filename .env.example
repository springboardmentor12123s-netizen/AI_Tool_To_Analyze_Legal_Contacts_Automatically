OPENAI_API_KEY=your_openai_api_key_here
CLAUSEAI_LLM_PROVIDER=groq
GROQ_API_KEY=your_first_groq_key_here
GROQ_API_KEY_2=your_second_groq_key_here
GROQ_API_KEY_3=your_third_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CLAUSEAI_GROQ_MAX_RETRIES=2
CLAUSEAI_GROQ_BACKOFF_BASE=0.3
CLAUSEAI_TEMPERATURE=0.15
CLAUSEAI_LLM_TIMEOUT_SECONDS=25
CLAUSEAI_DEFAULT_NUM_PREDICT=600
CLAUSEAI_REPORT_NUM_PREDICT=1500
CLAUSEAI_MAX_WORKERS=4
CLAUSEAI_AGENT_WORKERS=4
CLAUSEAI_CLAUSE_WORKERS=4
CLAUSEAI_AGENT_NUM_PREDICT=500
CLAUSEAI_ENABLE_MULTI_TURN_AGENT_INTERACTION=0
CLAUSEAI_ENABLE_PARALLEL_CLAUSE_EXTRACTION=0
CLAUSEAI_MODEL_CHAR_LIMIT=14000
CLAUSEAI_AGENT_CHAR_LIMIT=10000
CLAUSEAI_DEEP_ANALYSIS=0
CLAUSEAI_TURBO_MODE=1
CLAUSEAI_MAX_INDEX_CHUNKS=3
CLAUSEAI_CACHE_VERSION=7
